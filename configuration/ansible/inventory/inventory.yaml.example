all:
  vars:
    # NetBird Configuration
    netbird_domain: "vpn.example.com"
    netbird_version: "0.31.0"
    netbird_log_level: "info"
    netbird_admin_email: "admin@example.com"
    netbird_admin_password: "changeme"
    
    # Database Configuration
    database_type: "postgresql"
    database_engine: "postgres"
    database_dsn: "postgresql://netbird:password@db.example.com:5432/netbird?sslmode=require"
    database_endpoint: "db.example.com"
    db_host: "db.example.com"
    db_port: 5432
    db_name: "netbird"
    db_user: "netbird"
    db_password: "password"
    db_sslmode: "require"
    
    # Keycloak Configuration
    keycloak_url: "https://auth.example.com"
    keycloak_realm: "netbird"
    keycloak_client_id: "netbird-client"
    keycloak_backend_client_id: "netbird-backend"
    keycloak_backend_client_secret: "secret"
    keycloak_oidc_endpoint: "https://auth.example.com/realms/netbird"
    
    # Secrets
    relay_auth_secret: "generate-random-secret"
    netbird_encryption_key: "generate-random-key"
    coturn_password: "generate-random-password"
    
    # COTURN Configuration
    coturn_version: "4.6"
    coturn_port: 3478
    coturn_min_port: 49152
    coturn_max_port: 65535
    coturn_realm: "netbird.example.com"
    
    # Proxy Configuration
    proxy_type: "haproxy"
    haproxy_version: "3.2"
    haproxy_stats_password: "changeme"
    haproxy_health_check_interval: "2s"
    haproxy_health_check_timeout: "1s"
    haproxy_health_check_fall: 3
    haproxy_health_check_rise: 2
    haproxy_stick_table_size: "100k"
    haproxy_stick_table_expire: "30m"
    
    # ACME/TLS Configuration
    acme_provider: "letsencrypt"
    acme_email: "admin@example.com"
    
    # HA Configuration
    enable_clustering: false
    enable_haproxy_ha: false
    enable_pgbouncer: true
    
    # PgBouncer Configuration
    pgbouncer_listen_port: 6432
    pgbouncer_pool_mode: "transaction"
    pgbouncer_default_pool_size: 25
    pgbouncer_min_pool_size: 10
    pgbouncer_reserve_pool_size: 5
    pgbouncer_reserve_pool_timeout: 3
    pgbouncer_max_client_conn: 1000
    pgbouncer_max_db_connections: 100
    pgbouncer_max_user_connections: 100
    pgbouncer_server_lifetime: 3600
    pgbouncer_server_idle_timeout: 600
    pgbouncer_query_timeout: 0
    pgbouncer_query_wait_timeout: 120
    pgbouncer_client_idle_timeout: 0
    pgbouncer_stats_period: 60
    pgbouncer_health_check_period: 30
    pgbouncer_health_check_timeout: 15
    
    # Relay & STUN Addresses
    relay_addresses: ["relay1.example.com:443"]
    stun_addresses: ["stun.example.com:3478"]
    
    # Ansible Connection
    ansible_ssh_private_key_file: "~/.ssh/id_rsa"
    
  children:
    management:
      hosts:
        netbird-mgmt-1:
          ansible_host: 203.0.113.10
          private_ip: 10.0.1.10
          ansible_user: ubuntu
          
    reverse_proxy:
      hosts:
        netbird-proxy-1:
          ansible_host: 203.0.113.20
          private_ip: 10.0.2.10
          ansible_user: ubuntu
          keepalived_priority: 100
          
    relay:
      hosts:
        netbird-relay-1:
          ansible_host: 203.0.113.30
          private_ip: 10.0.3.10
          ansible_user: ubuntu
          relay_domain: "203.0.113.30"
