{
    email {{ acme_email }}
    {% if acme_provider == 'letsencrypt' %}
    acme_ca https://acme-v02.api.letsencrypt.org/directory
    {% elif acme_provider == 'zerossl' %}
    acme_ca https://acme.zerossl.com/v2/DV90
    {% endif %}
}

{{ netbird_domain }} {
    # SSL Configuration for AWS ephemeral domains
    {% if "compute.amazonaws.com" in netbird_domain %}
    tls internal
    {% endif %}

    # Security headers
    header {
        Strict-Transport-Security max-age=31536000;
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
    }

    # Management gRPC - HTTP/2 cleartext (h2c)
    reverse_proxy /management.ManagementService/* {
        to netbird-management:80
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        transport http {
            versions h2c
        }
    }

    # Signal gRPC - HTTP/2 cleartext (h2c)
    reverse_proxy /signalexchange.SignalExchange/* {
        to netbird-signal:80
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        transport http {
            versions h2c
        }
    }

    # Signal WebSocket
    reverse_proxy /ws-proxy/signal* {
        to netbird-signal:80
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        header_up X-Forwarded-For {remote_ip}
        header_up Upgrade {>Upgrade}
        header_up Connection {>Connection}
    }

    # Management WebSocket
    reverse_proxy /ws-proxy/management* {
        to netbird-management:80
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        header_up X-Forwarded-For {remote_ip}
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
    }

    # Relay WebSocket
    reverse_proxy /relay* {
        to netbird-relay:33080
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        header_up X-Forwarded-For {remote_ip}
        header_up Upgrade {>Upgrade}
        header_up Connection {>Connection}
    }

    # Management REST API
    reverse_proxy /api/* {
        to netbird-management:80
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        header_up X-Forwarded-For {remote_ip}
    }

    # Dashboard UI - catch-all (must be last)
    reverse_proxy /* {
        to netbird-dashboard:80
        header_up Host {host}
        header_up X-Real-IP {remote_ip}
        header_up X-Forwarded-For {remote_ip}
    }
}
