{{ netbird_domain }} {
    # Management API
    reverse_proxy /api/* {
        to netbird-management:80
    }
    
    # WebSocket - Signal
    reverse_proxy /ws-proxy/signal* {
        to netbird-signal:80
    }
    
    # gRPC - Signal (h2c = HTTP/2 cleartext)
    reverse_proxy /signalexchange.SignalExchange/* {
        to h2c://netbird-signal:80
    }
    
    # WebSocket - Management
    reverse_proxy /ws-proxy/management* {
        to netbird-management:80
    }
    
    # gRPC - Management
    reverse_proxy /management.ManagementService/* {
        to h2c://netbird-management:80
    }
    
    # Relay
    reverse_proxy /relay* {
        to netbird-management:80
    }
    
    # Dashboard (catch-all)
    reverse_proxy /* {
        to netbird-dashboard:80
    }
}
