# NetBird Management Configuration
# Generated by Ansible

Management:
  # HTTP/gRPC server configuration
  HttpServer:
    Address: ":80"
  
  # gRPC (separate port for internal/load balancer use in modern architecture)
  GrpcServer:
    Address: ":10000"

  # Database Connection (PostgreSQL for HA)
  StoreConfig:
    Engine: "postgres"
    PostgresConfig:
        DSN: "{{ postgres_dsn }}"

  # Identity Provider (Keycloak)
  IdpManagerConfig:
    ManagerType: "oidc"
    OidcConfig:
      Issuer: "{{ keycloak_url }}/realms/{{ keycloak_realm }}"
      Audience: "{{ keycloak_client_id }}"
      ClientID: "{{ keycloak_client_id }}"
      ClientSecret: "{{ keycloak_client_secret }}"
      metadataURL: "{{ keycloak_oidc_endpoint }}"

  # Signal Service
  Signal:
    URI: "https://{{ netbird_domain }}:443"

  # Relay Configuration
  Relay:
    Addresses:
      - "rels://{{ netbird_domain }}:443"
    Secret: "{{ relay_auth_secret }}"
  
  # TURN Configuration
  TurnConfig:
    TimeBasedCredentials: true
    Secret: "static-turn-secret-change-me" # Should be variable
    Turns:
      - Proto: udp
        URI: "turn:{{ netbird_domain }}:3478"
