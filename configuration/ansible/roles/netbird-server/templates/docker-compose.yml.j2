version: '3'

services:
  # NetBird Server (Management & Signal Service)
  # The modern image combines management and signal capabilities if requested, 
  # but here we keep them split for scaling as per official docs.
  management:
    image: netbirdio/management:{{ netbird_version | default('latest') }}
    container_name: netbird-management
    restart: unless-stopped
    networks:
      - netbird
    volumes:
      - /var/lib/netbird:/var/lib/netbird
      - /etc/netbird:/etc/netbird
    ports:
      - "{{ ansible_default_ipv4.address }}:8081:80"
      - "{{ ansible_default_ipv4.address }}:10000:10000"
      - "{{ ansible_default_ipv4.address }}:9000:9000"
    command: [
      "--config", "/etc/netbird/management.json",
      "--log-file", "console",
      "--log-level", "{{ netbird_log_level | default('info') }}"
    ]
    logging:
      driver: "json-file"
      options:
        max-size: "500m"
        max-file: "2"

  # Signal Service
  signal:
    image: netbirdio/signal:{{ netbird_version | default('latest') }}
    container_name: netbird-signal
    restart: unless-stopped
    networks:
      - netbird
    ports:
      - "{{ ansible_default_ipv4.address }}:10001:80"
    command: ["--port", "80"]
    logging:
      driver: "json-file"
      options:
        max-size: "500m"
        max-file: "2"

  # Dashboard
  dashboard:
    image: netbirdio/dashboard:{{ netbird_version | default('latest') }}
    container_name: netbird-dashboard
    restart: unless-stopped
    networks:
      - netbird
    environment:
      - NETBIRD_MGMT_API_ENDPOINT=https://{{ netbird_domain }}
      - NETBIRD_MGMT_GRPC_API_ENDPOINT=https://{{ netbird_domain }}
      - AUTH_AUDIENCE={{ keycloak_client_id }}
      - AUTH_CLIENT_ID={{ keycloak_client_id }}
      - AUTH_CLIENT_SECRET={{ keycloak_client_secret }}
      - AUTH_AUTHORITY={{ keycloak_url }}/realms/{{ keycloak_realm }}
      - AUTH_SUPPORTED_SCOPES=openid profile email groups
      - AUTH_REDIRECT_URI=https://{{ netbird_domain }}/nb-auth
      - AUTH_SILENT_REDIRECT_URI=https://{{ netbird_domain }}/nb-silent-auth
      - LETSENCRYPT_DOMAIN=none
    ports:
      - "{{ ansible_default_ipv4.address }}:8080:80"
    logging:
      driver: "json-file"
      options:
        max-size: "500m"
        max-file: "2"

  # Coturn
  coturn:
    image: coturn/coturn:latest
    container_name: netbird-coturn
    restart: unless-stopped
    network_mode: host
    volumes:
      - /etc/netbird/turnserver.conf:/etc/coturn/turnserver.conf:ro
    command:
      - -c
      - /etc/coturn/turnserver.conf
    logging:
      driver: "json-file"
      options:
        max-size: "500m"
        max-file: "2"

networks:
  netbird:
    name: netbird
