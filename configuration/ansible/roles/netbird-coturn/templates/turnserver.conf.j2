# NetBird Coturn configuration
listening-port={{ coturn_port }}
tls-listening-port=5349
# alt-listening-port=3479
# alt-tls-listening-port=5350

listening-ip=0.0.0.0
# relay-ip=0.0.0.0

# Realm for the TURN server
realm={{ coturn_realm }}

# Fingerprint in messages
fingerprint

# Use long-term credential mechanism
lt-cred-mech

# Static auth secret for NetBird
static-auth-secret={{ relay_auth_secret }}

# Port range for relay
min-port={{ coturn_min_port }}
max-port={{ coturn_max_port }}

# Logging
verbose
# log-file=/var/log/turnserver.log

# No stdout logging
no-stdout-log

# Use JSON logging if supported or just standard
# log-file=stdout

# Disable CLI
no-cli

# Recommended security settings
no-multicast-peers
no-tlsv1
no-tlsv1.1
