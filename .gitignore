.ansible-env
ansible_automation/.ansible/
*.tfstate

# Ignore environment / secret variable files
.env
*.env
*.env.*   # e.g. zitadel.env, zdb.env, dashboard.env, relay.env ...

# Ignore config files or secrets that you don’t want in repo
*.env        # in case you or others use other names
*.env.*.local
*.key
*.pem
*.crt

# Ignore log files, temporary files, caches
*.log
*.tmp
*.cache
*.bak

# Ignore OS-specific files
.DS_Store
Thumbs.db


# Ignore editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore build / compiled / generated files or directories (if any)
build/
dist/
target/
# Ignore sensitive or local-only directories
machinekey/

# Ignore Helm chart packages
*.tgz

# Ignore Helm lock files
Chart.lock
monitor-netbird/kubernetes/helm/monitoring-stack/charts/_loki/

# ============================================================================
# TERRAFORM - SECRETS & STATE
# ============================================================================
# Ignore Terraform state and binaries
**/.terraform/*
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# ⚠️ CRITICAL: Never commit Terraform variable files with secrets
*.tfvars              # All .tfvars files (contains real secrets)
*.tfvars.json         # JSON format .tfvars
*.tfvars.secret       # Explicitly marked secret tfvars
terraform.tfvars      # Default tfvars file
terraform.tfvars.json # Default JSON tfvars

# ============================================================================
# ANSIBLE - SECRETS & INVENTORY
# ============================================================================
# Never commit generated Ansible inventory with real values
**/inventory/terraform_inventory.yaml    # Auto-generated from Terraform
**/inventory/terraform_inventory.json    # Auto-generated from Terraform

# Ansible vault files and encrypted data
**/*.vault
**/*vault*
**/ansible-vault
**/vault-password*
**/vault.yml

# ============================================================================
# SSH & CREDENTIALS
# ============================================================================
# Never commit private SSH keys
**/private_key
**/private_key.*
**/id_rsa
**/id_rsa.*
**/*.pem
**/*.key
**/*_key

# ============================================================================
# ENVIRONMENT & CONFIGURATION
# ============================================================================
.env
.env.local
.env.*.local
.env.production.local
.env.secrets
*.env

# ============================================================================
# IDE & EDITOR
# ============================================================================
.quodo
.vivus
.agent
.elastic-copilot
.zencoder
.zenflow