# =============================================================================
# NETBIRD TERRAFORM VARIABLES EXAMPLE
# =============================================================================

# 1. CORE CONFIGURATION
netbird_domain = "netbird.example.com"
environment    = "prod" # dev, staging, prod

# Host configuration map
# roles: management (API/Signal/Dashboard), relay (Relay/STUN), proxy (Caddy/HAProxy)
netbird_hosts = {
  "netbird-all-in-one" = {
    public_ip  = "1.2.3.4"
    private_ip = "10.0.0.4" # Optional
    roles      = ["management", "relay", "proxy"]
    ssh_user   = "ubuntu"
  }
}

# 2. DATABASE CONFIGURATION
database_type        = "sqlite" # sqlite, postgresql
# database_mode      = "existing" # existing, create (managed)
# sqlite_database_path = "/var/lib/netbird/store.db"

# 3. IDENTITY PROVIDER (KEYCLOAK)
keycloak_url                 = "https://keycloak.example.com/auth"
keycloak_realm               = "netbird"
keycloak_admin_username      = "admin"
keycloak_admin_password      = "secure-password"
# keycloak_admin_client_secret = "rk9v8yew..." # Optional
keycloak_use_existing_realm = false

# 4. APPLICATION SECRETS
netbird_admin_email    = "admin@example.com"
netbird_admin_password = "secure-password"

# 5. INFRASTRUCTURE OPTIONS
proxy_type     = "caddy" # caddy, haproxy
acme_provider  = "letsencrypt" # letsencrypt, zerossl
acme_email     = "admin@example.com"
enable_ha      = false # Set true for multiple management nodes

# 6. SSH / ANSIBLE
ssh_private_key_path = "~/.ssh/id_rsa"

# 7. OPTIONAL OVERRIDES
# netbird_version        = "latest"
# netbird_log_level      = "info" # debug, info, warn, error
# docker_compose_version = "v2.24.0"
# relay_auth_secret      = "..." # Generated if empty
# netbird_encryption_key = "..." # Generated if empty
