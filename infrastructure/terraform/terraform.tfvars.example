# Example Terraform configuration
# Copy this file to terraform.tfvars and customize for your environment

# Enable cloud providers (set to true for providers you use)
use_aws   = false
use_gcp   = false
use_azure = false

# AWS Configuration (if use_aws = true)
# aws_region     = "us-east-1"
# aws_tag_key    = "NetBirdRole"
# aws_tag_values = ["netbird-primary", "netbird-relay"]
# aws_ssh_user   = "ubuntu"

# GCP Configuration (if use_gcp = true)
# gcp_project      = "my-project-id"
# gcp_region       = "us-central1"
# gcp_label_key    = "netbird-role"
# gcp_label_values = ["netbird-primary", "netbird-relay"]
# gcp_ssh_user     = "ubuntu"

# Azure Configuration (if use_azure = true)
# azure_subscription_id = "00000000-0000-0000-0000-000000000000"
# azure_resource_group  = "netbird-rg"
# azure_tag_key         = "NetBirdRole"
# azure_tag_values      = ["netbird-primary", "netbird-relay"]
# azure_ssh_user        = "ubuntu"
