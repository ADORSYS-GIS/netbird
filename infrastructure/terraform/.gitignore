# Terraform state and cache
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Terraform variables (may contain sensitive data)
terraform.tfvars
*.auto.tfvars

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc
