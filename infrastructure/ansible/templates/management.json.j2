{

  "Stuns": [
    {
      "Proto": "udp",
      "URI": "stun:{{ nb_netbird_domain }}:3478",
      "Username": "",
      "Password": ""
    }
  ],

  "TURNConfig": {
    "TimeBasedCredentials": false,
    "CredentialsTTL": "12h0m0s",
    "Secret": "{{ nb_turn_secret }}",
    "Turns": [
      {
        "Proto": "udp",
        "URI": "turn:{{ nb_netbird_domain }}:3478",
        "Username": "self",
        "Password": "{{ nb_turn_password }}"
      }
    ]
  },

  "Relay": {
    "Addresses": [
      "rels://{{ nb_netbird_domain }}/relay"
    ],
    "CredentialsTTL": "24h0m0s",
    "Secret": "{{ nb_relay_secret }}"
  },

  "Signal": {
    "Proto": "https",
    "URI": "{{ nb_netbird_domain }}:443",
    "Username": "",
    "Password": ""
  },

  "Datadir": "/var/lib/netbird/",

  "DataStoreEncryptionKey": "{{ nb_datastore_encryption_key }}",
  
  "StoreConfig": {
    "Engine": "sqlite"
  },

  "HttpConfig": {
    "AuthAudience": "{{ nb_auth_audience }}",
    "AuthIssuer": "{{ nb_auth_authority }}",
    "AuthKeysLocation": "{{ nb_auth_authority }}/protocol/openid-connect/certs",
    "OIDCConfigEndpoint": "{{ nb_auth_authority }}/.well-known/openid-configuration",
    "IdpSignKeyRefreshEnabled": false
  },

  "IdpManagerConfig": {
    "ManagerType": "keycloak",
    "ClientConfig": {
      "Issuer": "{{ nb_auth_authority }}",
      "TokenEndpoint": "{{ nb_auth_authority }}/protocol/openid-connect/token",
      "ClientID": "{{ nb_idp_mgmt_client_id }}",
      "ClientSecret": "{{ nb_idp_mgmt_client_secret }}",
      "GrantType": "client_credentials"
    },
    "ExtraConfig": {
      "AdminEndpoint": "{{ nb_auth_authority | replace('/realms/', '/admin/realms/') }}"
    }
  },

  "DeviceAuthorizationFlow": {
    "Provider": "integrated",
    "ProviderConfig": {
      "Audience": "{{ nb_auth_audience }}",
      "ClientID": "{{ nb_auth_client_id }}",
      "TokenEndpoint": "{{ nb_auth_authority }}/protocol/openid-connect/token",
      "DeviceAuthEndpoint": "{{ nb_auth_authority }}/protocol/openid-connect/auth/device",
      "Scope": "openid",
      "UseIDToken": false
    }
  },

  "PKCEAuthorizationFlow": {
    "ProviderConfig": {
      "Audience": "{{ nb_auth_audience }}",
      "ClientID": "{{ nb_auth_client_id }}",
      "AuthorizationEndpoint": "{{ nb_auth_authority }}/protocol/openid-connect/auth",
      "TokenEndpoint": "{{ nb_auth_authority }}/protocol/openid-connect/token",
      "Scope": "openid profile email groups",
      "RedirectURLs": [
        "https://{{ nb_netbird_domain }}",
        "https://{{ nb_netbird_domain }}/*"
      ],
      "UseIDToken": false
    }
  }
}
